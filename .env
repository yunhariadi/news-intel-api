# ─── App ────────────────────────────────────────────────────────────────────
APP_ENV=local
APP_NAME=news-intel-api
API_HOST=0.0.0.0
API_PORT=8000

# ─── Storage (v0.1 = Postgres + pgvector + Redis; NO OpenSearch yet) ─────────
DATABASE_URL=postgresql+psycopg://news:news@postgres:5432/news_intel
REDIS_URL=redis://redis:6379/0
# OPENSEARCH_URL=        # intentionally unset for v0.1 — Postgres FTS is enough

# ─── Time ────────────────────────────────────────────────────────────────────
# Indonesia spans WIB/WITA/WIT. Store source-local tz + UTC; compute windows in
# UTC. This is only the display default, not the single source of truth.
DEFAULT_TIMEZONE=Asia/Jakarta
FETCH_INTERVAL_SECONDS=300

# ─── Ingestion / fetching ────────────────────────────────────────────────────
USER_AGENT=NewsIntelBot/0.1 (+https://yourdomain.com/bot-info; contact: you@yourdomain.com)
FETCH_TIMEOUT_SECONDS=15
PER_SOURCE_MAX_CONCURRENCY=2
CIRCUIT_BREAKER_ERROR_THRESHOLD=5

# ─── Deduplication / syndication ─────────────────────────────────────────────
SIMHASH_HAMMING_MAX=3            # near-dup threshold for content_fingerprint
NEAR_DUP_WINDOW_HOURS=48

# ─── Trending (mirror packages/ranking/trending.py constants) ────────────────
# These are calibration knobs; keep in sync with the reference module + tests.
TREND_SOURCE_CAP=20
TREND_DIVERSITY_COEF=1.0
TREND_BURST_COEF=0.8
TREND_BURST_CAP=5.0
TREND_MIN_MENTIONS=3
TREND_MIN_DISTINCT_SOURCES=2
# reference_scale is computed at runtime as a rolling P95 of raw scores;
# this is only the cold-start fallback before enough history exists.
TREND_REFERENCE_SCALE_FALLBACK=12.0

# ─── Compliance (enforced by packages/compliance/invariants.py) ──────────────
MAX_EXCERPT_CHARS=300           # C1: hard cap on stored excerpts
QUOTE_CONFIDENCE_FLOOR=0.75     # I1: below this, a quote is never exposable
RAW_BODY_RETENTION_HOURS=24     # P3: transient raw bodies, used then dropped
DSR_SLA_HOURS=72                # P2: data-subject erasure/rectify SLA

# ─── Layer B (LLM narration only — off by default) ───────────────────────────
ENABLE_LLM_ENRICHMENT=false
LLM_API_KEY=

# ─── API auth ────────────────────────────────────────────────────────────────
API_KEY_SECRET=change_this_secret
